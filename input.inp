// Input file


Model {
    rho  = 1
    nu   = 1
}


Mesh {

    domain = (10, 3, 5)

    Grid X {
        
        Segment {
            bounds     = (0, 4)
            nCells     = 40
            biasFactor = 1
        }

    }


    Grid Y {
        Segment {
            bounds     = (0, 4)
            nCells     = 40
            biasFactor = 6
        }
    }


    Grid Z {
        Segment {
            bounds     = (0, 10)
            nCells     = 100
            biasFactor = 1
        }
    }
}


BoundaryConditions
{

    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }

    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    +y {
        u = uniform, 1
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = extrapolated
    }

    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}


Solver {

    planeSweepDirection = z
    lineSweepDirection  = y

}
