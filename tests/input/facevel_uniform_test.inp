// Input file for testing face velocities with uniform boundary condition

#include "facevel_test_mesh.inp"

BoundaryConditions
{

    +x {
        u = uniform, 5.90
        v = uniform, 5.90
        w = uniform, 5.90
        p = uniform, 5.90
    }

    -x {
        u = uniform, 5.90
        v = uniform, 5.90
        w = uniform, 5.90
        p = uniform, 5.90
    }

    +y {
        u = uniform, 5.90
        v = uniform, 5.90
        w = uniform, 5.90
        p = uniform, 5.90
    }

    -y {
        u = uniform, 5.90
        v = uniform, 5.90
        w = uniform, 5.90
        p = uniform, 5.90
    }

    +z {
        u = uniform, 5.90
        v = uniform, 5.90
        w = uniform, 5.90
        p = uniform, 5.90
    }

    -z {
        u = uniform, 5.90
        v = uniform, 5.90
        w = uniform, 5.90
        p = uniform, 5.90
    }
}

Model {
    rho  = 1
    nu   = 1
}


Solver {

    planeSweepDirection = +z
    lineSweepDirection = +y

}

