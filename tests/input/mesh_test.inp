// Input file used for testing the mesh.
// Only the mesh section should be used

Mesh {

    domain = (4, 4, 4)

    Grid X {
        Segment {
            bounds     = (0, 1)
            nCells     = 4
            biasFactor = 2
        }

        Segment {
            bounds     = (1, 3)
            nCells     = 6
            biasFactor = 1
        }

        Segment {
            bounds     = (3, 4)
            nCells     = 4
            biasFactor = -2
        }
    }


    Grid Y {
        Segment {
            bounds     = (0, 1)
            nCells     = 4
            biasFactor = 2
        }

        Segment {
            bounds     = (1, 3)
            nCells     = 6
            biasFactor = 1
        }

        Segment {
            bounds     = (3, 4)
            nCells     = 4
            biasFactor = -2
        }
    }


    Grid Z {
        Segment {
            bounds     = (0, 1)
            nCells     = 4
            biasFactor = 2
        }

        Segment {
            bounds     = (1, 3)
            nCells     = 6
            biasFactor = 1
        }

        Segment {
            bounds     = (3, 4)
            nCells     = 4
            biasFactor = -2
        }
    }
}



Model {
    rho  = 1
    nu   = 1
}


BoundaryConditions
{

    +x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    -x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    +y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }
}


Solver {

    planeSweepDirection = +z
    lineSweepDirection = +y

}
