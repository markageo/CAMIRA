// Input file used for testing the mesh.
// Only the mesh section should be used

Mesh {

    domain = (4, 4, 4)

    Grid x {
        Segment {
            bounds     = (0, 1)
            nCells     = 4
            biasFactor = 2
        }

        Segment {
            bounds     = (1, 3)
            nCells     = 6
            biasFactor = 1
        }

        Segment {
            bounds     = (3, 4)
            nCells     = 4
            biasFactor = -2
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 1)
            nCells     = 4
            biasFactor = 2
        }

        Segment {
            bounds     = (1, 3)
            nCells     = 6
            biasFactor = 1
        }

        Segment {
            bounds     = (3, 4)
            nCells     = 4
            biasFactor = -2
        }
    }


    Grid z {
        Segment {
            bounds     = (0, 1)
            nCells     = 4
            biasFactor = 2
        }

        Segment {
            bounds     = (1, 3)
            nCells     = 6
            biasFactor = 1
        }

        Segment {
            bounds     = (3, 4)
            nCells     = 4
            biasFactor = -2
        }
    }
}



Model {
    rho  = 1
    nu   = 1
}


InitialConditions
{
    u = 0
    v = 0
    w = 0
    p = 0
}

BoundaryConditions
{

    +x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    -x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    +y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }
}


Solver {

    planeSweepDirection = +z
    lineSweepDirection = +y

    Schemes {
        linearisation = Picard
        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1
    }

    PlaneSweeping {
        maxOuterIterations = 1
        maxOuterResiduals = 1e-5

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

        maxInnerIterations = 10
        maxInnerResiduals = 1e-3
    }
    
    PlaneSolver {
        type = SUGS
        maxIterations = 100
        maxResiduals = 1e-3

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1
    }

    LineSolver {
        type = SUGS
        maxIterations = 10
        maxResiduals = 1e-3

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1
    }

}

