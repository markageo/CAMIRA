// Mesh used for testing face velocities

Mesh {

    domain = (2, 2, 2)

    Grid x {
        Segment {
            bounds     = (0, 2)
            nCells     = 7
            biasFactor = 2
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 2)
            nCells     = 7
            biasFactor = 2
        }
    }


    Grid z {
        Segment {
            bounds     = (0, 2)
            nCells     = 7
            biasFactor = 2
        }
    }
}

