// Laminar duct in z direction

Model {
    rho  = 1
    nu   = 0.001
}

Mesh {

    domain = (0.5, 0.1, 0.1)

    // Streamwise
    Grid x {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 100
            biasFactor = 1
        }
    }


    // Cross stream
    Grid y {
        Segment {
            bounds     = (0, 0.1)
            nCells     = 40
            biasFactor = 3
        }
    }


    // Symmetry
    Grid z {
        Segment {
            bounds     = (0, 0.1)
            nCells     = 20
            biasFactor = 1
        }
    }
}


InitialConditions
{
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Freestream
    +y {
        u = uniform, 1
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}



Solver {

    Schemes {
        linearisation = Picard
        momentumInterpolation = implicit
        advectionScheme = upwind
        faceInterpolationScheme = weightedLinear

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 1000
        maxOuterResiduals = 1e-4
    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 1
        maxResiduals = 1e-5

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

}

Output {

    residualHistoryFilename = "residual_history.csv"
    fieldOutputFilename = "fields.vtk"

    Monitors {
        Probe {
            filename = "probe1.csv"
            location = (0.5, 0.98, 0.5)
        }
    }

}
