// Laminar duct in z direction

Model {
    rho  = 1
    nu   = 0.0001
}

Mesh {

    domain = (0.5, 0.1, 0.1)

    // Streamwise
    Grid x {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 100
            biasFactor = 1
        }
    }


    // Cross stream
    Grid y {
        Segment {
            bounds     = (0, 0.1)
            nCells     = 40
            biasFactor = 3
        }
    }


    // Symmetry
    Grid z {
        Segment {
            bounds     = (0, 0.1)
            nCells     = 20
            biasFactor = 1
        }
    }
}


InitialConditions
{
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Freestream
    +y {
        u = uniform, 1
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}



Solver {

    Schemes {
        linearisation = Picard
        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        advectionScheme = upwind
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 1000
        maxOuterResiduals = 1e-4
    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 10
        maxResiduals = 1e-5

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

        PlaneSolver {
            type = SUGS
            maxIterations = 1
            maxResiduals = 1e-5

            momentumRelaxation = (1, 1, 1)
            pressureRelaxation = 1

            planeSweepDirection = +z


            LineSolver {
                type = SUGS
                maxIterations = 1
                maxResiduals = 1e-5

                momentumRelaxation = (1, 1, 1)
                pressureRelaxation = 1

                lineSweepDirection = +y
            }
        }
    }

}
