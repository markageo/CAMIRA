// Laminar duct in z direction

Model {
    rho  = 1
    nu   = 1
}

Mesh {

    domain = (0.5, 0.1, 0.5)

    // Streamwise
    Grid x {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 25
            biasFactor = 1
        }
    }


    // Symmetry
    Grid y {
        Segment {
            bounds     = (0, 0.1)
            nCells     = 10
            biasFactor = 1
        }
    }


    // Cross stream
    Grid z {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 25
            biasFactor = 5
        }
    }
}


InitialConditions
{
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    -y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Free stream
    +z {
        u = uniform, 1
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}



Solver {

    Schemes {
        linearisation = Picard
        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 1000
        maxOuterResiduals = 1e-6
    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 1
        maxResiduals = 1e-3

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

        PlaneSolver {
            type = SUGS
            maxIterations = 5
            maxResiduals = 1e-3

            momentumRelaxation = (1, 1, 1)
            pressureRelaxation = 1

            planeSweepDirection = +y


            LineSolver {
                type = SUGS
                maxIterations = 10
                maxResiduals = 1e-3

                momentumRelaxation = (1, 1, 1)
                pressureRelaxation = 1

                lineSweepDirection = +x
            }
        }
    }

}
