// Laminar duct in x direction

Model {
    rho  = 1
    nu   = 0.001
}

Mesh {

    domain = (4, 0.5, 0.5)

    // Streamwise
    Grid x {
        Segment {
            bounds     = (0, 4)
            nCells     = 64
            biasFactor = 1
        }
    }

    // Cross stream
    Grid y {
        Segment {
            bounds     = (0, 0.25)
            nCells     = 8
            biasFactor = 2
        }

         Segment {
            bounds     = (0.25, 0.5)
            nCells     = 8
            biasFactor = -2
        }
    }

    // Cross stream
    Grid z {
        Segment {
            bounds     = (0, 0.25)
            nCells     = 8
            biasFactor = 2
        }

         Segment {
            bounds     = (0.25, 0.5)
            nCells     = 8
            biasFactor = -2
        }
    }
    
}


InitialConditions
{
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}



Solver {

    Schemes {
        linearisation = Picard
        momentumInterpolation = implicit
        advectionScheme = upwind
        faceInterpolationScheme = weightedLinear

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 1000
        maxOuterResiduals = 1e-4
    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 1
        maxResiduals = 1e-4

        planeSweepDirection = +y
        lineSweepDirection = +x

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

}

Output {

    residualHistoryFilename = "residual_history.csv"
    fieldOutputFilename = "fields.vtk"
    fieldWriteInterval = 0

    Monitors {
        Probe {
            filename = "probe1.csv"
            location = (0.5, 0.98, 0.5)
        }
    }

}
