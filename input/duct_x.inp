// Laminar duct in z direction

Model {
    rho  = 1
    nu   = 1
}

Mesh {

    domain = (1, 0.5, 0.1)

    // Streamwise
    Grid x {
        Segment {
            bounds     = (0, 1)
            nCells     = 100
            biasFactor = 1
        }
    }

    // Cross stream
    Grid y {
        Segment {
            bounds     = (0, 0.25)
            nCells     = 16
            biasFactor = 1
        }

        Segment {
            bounds     = (0.25, 0.5)
            nCells     = 16
            biasFactor = 1
        }
    }

    // Cross stream
    Grid z {
        Segment {
            bounds     = (0, 0.25)
            nCells     = 16
            biasFactor = 1
        }

        Segment {
            bounds     = (0.25, 0.5)
            nCells     = 16
            biasFactor = 1
        }
    }
    
}


InitialConditions
{
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}



Solver {

    Schemes {
        linearisation = Picard

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        advectionScheme = upwind
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 10000
        maxOuterResiduals = 1e-12
    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 1
        maxResiduals = 1e-3

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

        PlaneSolver {
            type = SUGS
            maxIterations = 10
            maxResiduals = 1e-5

            momentumRelaxation = (1, 1, 1)
            pressureRelaxation = 1

            planeSweepDirection = +z


            LineSolver {
                type = SUGS
                maxIterations = 1
                maxResiduals = 1e-3

                momentumRelaxation = (1, 1, 1)
                pressureRelaxation = 1

                lineSweepDirection = +y
            }
        }
    }

}
