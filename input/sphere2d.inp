// Sphere flow

Model {
    rho  = 1
    nu   = 0.025
}

Mesh {

    domain = (40, 40, 1)

    Grid x {
        Segment {
            bounds     = (0, 40)
            nCells     = 512
            biasFactor = 1
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 40)
            nCells     = 512
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 1)
            nCells     = 1
            biasFactor = 1
        }
    }
}


InitialConditions
{
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    -y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    Sphere {
        centerPosition = (16, 20, 0.5)
        diameter       = 1
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = QUICK
        advectionBlendingFactor = 1
        faceInterpolationScheme = average

        implicitMomentumRelaxation = (0.4, 0.4, 0.4)
        implicitPressureRelaxation = 1

        maxOuterIterations = 1000
        maxContinuityOuterResidual = 1e-12
        maxMomentumOuterResiduals  = (1e-12, 1e-12, 1e-12)

    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 13
        maxResiduals = 1e-3

        planeSweepDirection = +x
        lineSweepDirection = +y

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 2

        maxPreSmoothingIterations = 2
        maxPreSmoothingResiduals = 0

        maxPostSmoothingIterations = 2
        maxPostSmoothingResiduals = 0

        maxCoarseGridIterations = 100
        maxCoarseGridResiduals  = 1e-4
        
        maxFineGridIterations   = 2
        maxFineGridResiduals    = 0
        
    }

}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

}
