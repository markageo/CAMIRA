// Backwards facing step with no inflow region

Model {
    rho  = 1
    nu   = 0.01
}

Mesh {

    domain = (7, 2, 1)

    Grid x {
        Segment {
            bounds     = (0, 7)
            nCells     = 63
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 2)
            nCells     = 18
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 1)
            nCells     = 9
            biasFactor = 1
        }
    }
}


InitialConditions
{
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = profile1D, "bfs_inflow.prof"
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        faceInterpolationScheme = weightedLinear

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 500
        maxContinuityOuterResidual = 1e-6
        maxMomentumOuterResiduals  = (1e-6, 1e-6, 1e-6)

    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 5
        maxResiduals = 1e-1

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    fieldWriteInterval      = 0

    Monitors {
        Probe {
            filename = "output/probe1.csv"
            location = (1, 0.5, 0.5)
        }
    }

}
