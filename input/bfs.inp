// Backwards facing step with no inflow region
// Re = 200, nonuniform grid

Model {
    rho  = 1
    nu   = 0.005
    transient = yes
}

Mesh {

    domain = (6, 3, 1)

    Grid x {
        Segment {
            bounds     = (0, 6)
            nCells     = 192
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 3)
            nCells     = 96
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 1)
            nCells     = 32
            biasFactor = 1
        }
    }
}



InitialConditions
{
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        //u = profile1D, "bfs_inflow.prof"
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


Solver {

    Schemes {

        timeScheme              = backwardsEuler
        timeStepSize            = 0.001
        numberOfTimesteps       = 10

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1
        faceInterpolationScheme = weightedLinear

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 500000
        maxContinuityOuterResidual = 1e-16
        maxMomentumOuterResiduals   = (1e-16, 1e-16, 1e-16)

    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 1
        maxResiduals = 0

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 0

        maxPreSmoothingIterations = 2
        maxPreSmoothingResiduals = 0

        maxPostSmoothingIterations = 2
        maxPostSmoothingResiduals = 0

        maxCoarseGridIterations = 500
        maxCoarseGridResiduals  = 1e-4
        
        maxFineGridIterations   = 3
        maxFineGridResiduals    = 0
        
    }

}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    fieldWriteInterval      = 0

    Monitors {
        Probe {
            filename = "output/probe1.csv"
            location = (1, 0.5, 0.5)
        }
    }

}
