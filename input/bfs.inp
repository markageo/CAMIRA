// Backwards facing step with no inflow region

Model {
    rho  = 1
    nu   = 0.005
}

Mesh {

    domain = (6, 3, 1)

    Grid x {
        Segment {
            bounds     = (0, 6)
            nCells     = 48
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 4
            biasFactor = 1
        }

        Segment {
            bounds     = (0.5, 3)
            nCells     = 20
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 4
            biasFactor = 1
        }

        Segment {
            bounds     = (0.5, 1)
            nCells     = 4
            biasFactor = 1
        }
    }
}



InitialConditions
{
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = profile1D, "bfs_inflow.prof"
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1
        faceInterpolationScheme = weightedLinear

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 10000
        maxContinuityOuterResidual = 1e-5
        maxMomentumOuterResiduals   = (1e-5, 1e-5, 1e-5)

    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 3
        maxResiduals = 0

        planeSweepDirection = +x
        lineSweepDirection = +y

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        maxCoarseLevels = 0

        maxPreSmoothingIterations = 2
        maxPreSmoothingResiduals = 0

        maxPostSmoothingIterations = 2
        maxPostSmoothingResiduals = 0

        maxCoarseGridIterations = 1000
        maxCoarseGridResiduals  = 1e-6
        
        maxFineGridIterations   = 3
        maxFineGridResiduals    = 0
        
    }

}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    fieldWriteInterval      = 0

    Monitors {
        Probe {
            filename = "output/probe1.csv"
            location = (1, 0.5, 0.5)
        }
    }

}
