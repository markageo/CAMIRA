// Rectilinear mesh for laminar flat plate

Mesh {

    domain = (1, 1, 1)

    Grid X {
        
        Segment {
            bounds     = (0, 1)
            nCells     = 5
            biasFactor = 1
        }

    }


    Grid Y {
        Segment {
            bounds     = (0, 1)
            nCells     = 5
            biasFactor = 1
        }
    }


    Grid Z {
        Segment {
            bounds     = (0, 1)
            nCells     = 5
            biasFactor = 1
        }
    }
}

