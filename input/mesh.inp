// Rectilinear mesh for laminar flat plate

Mesh {

    domain = (10, 3, 5)

    Grid X {
        
        Segment {
            bounds     = (0, 4)
            nCells     = 40
            biasFactor = 1
        }

    }


    Grid Y {
        Segment {
            bounds     = (0, 4)
            nCells     = 40
            biasFactor = 6
        }
    }


    Grid Z {
        Segment {
            bounds     = (0, 10)
            nCells     = 100
            biasFactor = 1
        }
    }
}

