// Sphere flow

Model {
    rho  = 1
    nu   = 0.00666666
    transient = no
}

Mesh {

    domain = (24, 12, 12)

    Grid x {
        Segment {
            bounds     = (0, 24)
            nCells     = 240
            biasFactor = 1
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 12)
            nCells     = 120
            biasFactor = 1
        }
    }


    Grid z {
        Segment {
            bounds     = (0, 12)
            nCells     = 120
            biasFactor = 1
        }
    }
}


InitialConditions
{
    type = uniform
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    -y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {

    boundaryTreatement = directionalImmersedBoundary

    Sphere {
        centerPosition = (10, 6, 6)
        diameter       = 1
    }
}


Solver {

    Schemes {

        timeScheme              = backwardsEuler
        timeStepSize            = 0.5
        numberOfTimesteps       = 100

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = QUICK
        advectionBlendingFactor = 1
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 100
        maxContinuityOuterResidual = 1e-3
        maxMomentumOuterResiduals  = (1e-3, 1e-3, 1e-3)

    }
    
    Smoother {

        type = nestedLineSymmetric
        maxIterations = 1
        maxResiduals = 1e-3

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 2

        preSmoothingIterations = 3
        postSmoothingIterations = 3
        fineGridIterations   = 2

        maxCoarseGridIterations = 500
        maxCoarseGridResiduals  = 1e-6
        
    }

}


Output {

    residualHistoryFilename = "output/residualHistory.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

    Monitors {
        ForceCalculator {
            filename = "output/forces.csv"
        }
    }
    

}
