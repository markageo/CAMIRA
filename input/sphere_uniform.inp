// Sphere flow

Model {
    rho  = 1
    nu   = 0.05
    transient = no
}

Mesh {

    domain = (10, 5, 5)

    Grid x {
        Segment {
            bounds     = (0, 10)
            nCells     = 480
            biasFactor = 1
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 5)
            nCells     = 240
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 5)
            nCells     = 240
            biasFactor = 1
        }
    }
}


InitialConditions
{
    type = uniform
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    -y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    Sphere {
        centerPosition = (2.5, 2.5, 2.5)
        diameter       = 1
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = central
        advectionBlendingFactor = 1
        faceInterpolationScheme = average

        implicitMomentumRelaxation = (0.6, 0.6, 0.6)
        implicitPressureRelaxation = 1

        maxOuterIterations = 1000
        maxContinuityOuterResidual = 1e-6
        maxMomentumOuterResiduals  = (1e-6, 1e-6, 1e-6)

    }
    
    LinearSolver {

        type = domainSymmetric
        maxIterations = 4
        maxResiduals = 1e-3

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 3

        preSmoothingIterations = 3
        postSmoothingIterations = 3
        fineGridIterations   = 2

        maxCoarseGridIterations = 500
        maxCoarseGridResiduals  = 1e-6
        
    }

}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

}
