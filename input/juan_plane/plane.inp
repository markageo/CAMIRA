// Plane primary input file

Model {
    nu   = 1.5e-5
    transient = no
    TurbulenceModel {
        //#include "plane-ZEQ3.inp"
        model = PrandtlZeroEquation
    }
}

Mesh {
    #include "plane-nonuniform-mesh.inp"
}


InitialConditions
{    
    type = uniform
    u = 15
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 15
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    boundaryTreatment = directionalImmersedBoundary
    
    FromFile {
        type = STL
        filename = "plane-geometry.stl"
        rotation = (0, 15, 0)
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 10
        maxContinuityOuterResidual = 1e-3
        maxMomentumOuterResiduals  = (1e-3, 1e-3, 1e-3)

    }
    
    Smoother {

        type = domainSymmetricParallel
        maxIterations = 2
        maxResiduals = 1e-5

        planeSweepDirection = +z
        lineSweepDirection = +y

        eddyViscosityRelaxation = 1
        momentumRelaxation      = (0.85, 0.85, 0.85)
        pressureRelaxation      = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 3

        preSmoothingIterations = 2
        postSmoothingIterations = 2
        fineGridIterations   = 3

        maxCoarseGridIterations = 100
        maxCoarseGridResiduals  = 1e-8
        
    }

}

Parallel {
    numberOfThreads = 8
}

Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

    Monitors {
        ForceCalculator {
            filename = "output/forces.csv"
        }
    }
}
