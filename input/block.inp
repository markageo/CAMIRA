// Block flow

Model {
    rho  = 1
    nu   = 0.02
}

Mesh {

    domain = (10, 4, 3)

    Grid x {
        Segment {
            bounds     = (0, 1.8)
            nCells     = 44
            biasFactor = -2
        }

        Segment {
            bounds     = (1.8, 3.2)
            nCells     = 62
            biasFactor = 1
        }

        Segment {
            bounds     = (3.2, 10)
            nCells     = 194
            biasFactor = 3
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 1)
            nCells     = 44
            biasFactor = 1
        }

        Segment {
            bounds     = (1, 4)
            nCells     = 76
            biasFactor = 2
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 0.8)
            nCells     = 24
            biasFactor = -2.5
        }

        Segment {
            bounds     = (0.8, 2.2)
            nCells     = 62
            biasFactor = 1
        }

        Segment {
            bounds     = (2.2, 3)
            nCells     = 24
            biasFactor = 2.5
        }
    }
}


InitialConditions
{
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    Block {
        centerPosition = (2.5, 0.5, 1.5)
        dimensions     = (1, 1, 1)
        rotation       = (0, 45, 0)
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = average

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 100
        maxContinuityOuterResidual = 1e-16
        maxMomentumOuterResiduals  = (1e-16, 1e-16, 1e-16)

    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 2
        maxResiduals = 1e-3

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 2

        maxPreSmoothingIterations = 2
        maxPreSmoothingResiduals = 0

        maxPostSmoothingIterations = 2
        maxPostSmoothingResiduals = 0

        maxCoarseGridIterations = 100
        maxCoarseGridResiduals  = 1e-4
        
        maxFineGridIterations   = 2
        maxFineGridResiduals    = 0
        
    }

}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

    Monitors {
        Probe {
            filename = "output/probe1.csv"
            location = (1, 0.5, 0.5)
        }
    }

}
