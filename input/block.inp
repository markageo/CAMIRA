// Block flow

Model {
    rho  = 1
    nu   = 0.05
    transient = no
}

Mesh {

    domain = (10, 4, 3)

    Grid x {
        Segment {
            bounds     = (0, 1.8)
            nCells     = 22
            biasFactor = -2
        }

        Segment {
            bounds     = (1.8, 3.2)
            nCells     = 31
            biasFactor = 1
        }

        Segment {
            bounds     = (3.2, 10)
            nCells     = 97
            biasFactor = 3
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 1)
            nCells     = 22
            biasFactor = 1
        }

        Segment {
            bounds     = (1, 4)
            nCells     = 38
            biasFactor = 2
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 0.8)
            nCells     = 12
            biasFactor = -2.5
        }

        Segment {
            bounds     = (0.8, 2.2)
            nCells     = 31
            biasFactor = 1
        }

        Segment {
            bounds     = (2.2, 3)
            nCells     = 12
            biasFactor = 2.5
        }
    }
}


InitialConditions
{
    type = uniform
    u = 0
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    Block {
        centerPosition = (2.5, 0.5, 1.5)
        dimensions     = (1, 1, 1)
        rotation       = (0, 45, 0)
    }

    //FromFile {
    //    type = STL
    //    filename = "cube_geometry.stl"
    //}
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1
        faceInterpolationScheme = weightedLinear

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 100
        maxContinuityOuterResidual = 1e-6
        maxMomentumOuterResiduals   = (1e-6, 1e-6, 1e-6)

    }
    
    LinearSolver {

        type = nestedLineSymmetric
        maxIterations = 5
        maxResiduals = 1e-3

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 3

        preSmoothingIterations = 3
        postSmoothingIterations = 3
        fineGridIterations   = 2

        maxCoarseGridIterations = 500
        maxCoarseGridResiduals  = 1e-6
        
    }

}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

    Monitors {
        Probe {
            filename = "output/probe1.csv"
            location = (1, 0.5, 0.5)
        }

        ForceCalculator {
            filename = "output/forces.csv"
        }
    }

}
