// 45 degree angled block flow
// Re = 50, uniform grid

Model {
    rho  = 1
    nu   = 0.02
}

Mesh {

    domain = (10, 4, 3)

    Grid x {
        Segment {
            bounds     = (0, 10)
            nCells     = 300
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 4)
            nCells     = 120
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 3)
            nCells     = 90
            biasFactor = 1
        }
    }
}


InitialConditions
{
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    Block {
        centerPosition = (2.5, 0.5, 1.5)
        dimensions     = (1, 1, 1)
        rotation       = (0, 45, 0)
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = weightedLinear

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 100
        maxContinuityOuterResidual = 1e-6
        maxMomentumOuterResiduals  = (1e-6, 1e-6, 1e-6)

    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 2
        maxResiduals = 1e-3

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = W
        maxCoarseLevels = 2

        maxPreSmoothingIterations = 2
        maxPreSmoothingResiduals = 0

        maxPostSmoothingIterations = 2
        maxPostSmoothingResiduals = 0

        maxCoarseGridIterations = 100
        maxCoarseGridResiduals  = 1e-4
        
        maxFineGridIterations   = 2
        maxFineGridResiduals    = 0
        
    }

}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

    Monitors {
        Probe {
            filename = "output/probe1.csv"
            location = (1, 0.5, 0.5)
        }
    }

}
