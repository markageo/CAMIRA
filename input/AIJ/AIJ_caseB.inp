// AIJ case B, turbulent flow over 1:4:4 block

Model {
    nu   = 1.5e-5
    transient = no
    TurbulenceModel {
        model = ZEQ4
        heightAxis = z
        averageBuildingHeight = 0.2
        averageBuildingWidth = 0.2
        referenceHeight = 0.2
    }
}

Mesh {

    domainLowerBounds = (0, 0, 0)
    domainUpperBounds = (4.05, 2.2, 1.2)

    Grid x {
        Segment {
            bounds     = (0, 4.05)
            nCells     = 85
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 2.2)
            nCells     = 50
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 1.2)
            nCells     = 44
            biasFactor = 1
        }
    }
}


InitialConditions
{    
    type = uniform
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = profile1D, "AIJ_caseB_inflow.prof"
        // u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    -y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    boundaryTreatement = directionalImmersedBoundary
    Block {
        centerPosition = (1.025, 1.1, 0.1)
        dimensions     = (0.05, 0.2, 0.2)
        rotation       = (0, 0, 35)
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 99
        maxContinuityOuterResidual = 1e-8
        maxMomentumOuterResiduals  = (1e-8, 1e-8, 1e-8)

    }
    
    Smoother {

        type = domainSymmetricParallel
        maxIterations = 3
        maxResiduals = 1e-5

        planeSweepDirection = +z
        lineSweepDirection = +y

        eddyViscosityRelaxation = 1
        momentumRelaxation      = (0.8, 0.8, 0.8)
        pressureRelaxation      = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 3

        preSmoothingIterations = 2
        postSmoothingIterations = 2
        fineGridIterations   = 3

        maxCoarseGridIterations = 50
        maxCoarseGridResiduals  = 1e-8
        
    }

}

Parallel {
    numberOfThreads = 8
}

Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 1

    Monitors {
        ForceCalculator {
            filename = "output/forces.csv"
        }
    }

}
