// Sphere flow

Model {
    rho  = 1
    nu   = 0.05
    transient = no
}

Mesh {

    domain = (10, 5, 5)

    Grid x {
        Segment {
            bounds     = (0, 2)
            nCells     = 40
            biasFactor = -2
        }

        Segment {
            bounds     = (2, 3)
            nCells     = 40
            biasFactor = 1
        }

        Segment {
            bounds     = (3, 10)
            nCells     = 120
            biasFactor = 3.5
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 2)
            nCells     = 30
            biasFactor = -3
        }

        Segment {
            bounds     = (2, 3)
            nCells     = 40
            biasFactor = 1
        }

        Segment {
            bounds     = (3, 5)
            nCells     = 30
            biasFactor = 3
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 2)
            nCells     = 30
            biasFactor = -3
        }

        Segment {
            bounds     = (2, 3)
            nCells     = 40
            biasFactor = 1
        }

        Segment {
            bounds     = (3, 5)
            nCells     = 30
            biasFactor = 3
        }
    }
}


InitialConditions
{
    type = uniform
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    -y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    // Sphere {
    //     centerPosition = (2.5, 2.5, 2.5)
    //     diameter       = 1
    // }

    FromFile {
        type = STL
        filename = "input/sphere_external_geometry.stl"
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1
        faceInterpolationScheme = weightedLinear

        implicitMomentumRelaxation = (0.6, 0.6, 0.6)
        implicitPressureRelaxation = 1

        maxOuterIterations = 100
        maxContinuityOuterResidual = 1e-6
        maxMomentumOuterResiduals  = (1e-6, 1e-6, 1e-6)

    }
    
    LinearSolver {

        type = nestedLineSymmetric
        maxIterations = 4
        maxResiduals = 1e-3

        planeSweepDirection = +y
        lineSweepDirection = +x

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 3

        preSmoothingIterations = 3
        postSmoothingIterations = 3
        fineGridIterations   = 2

        maxCoarseGridIterations = 500
        maxCoarseGridResiduals  = 1e-6
        
    }

}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

}
