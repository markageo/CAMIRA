// Sphere flow

Model {
    rho  = 1
    nu   = 0.05
    transient = no
}

Mesh {

    domain = (24, 12, 12)

    Grid x {
        Segment {
            bounds     = (0, 9.5)
            nCells     = 85
            biasFactor = -5.5
        }

        Segment {
            bounds     = (9.5, 10.5)
            nCells     = 28
            biasFactor = 1
        }

        Segment {
            bounds     = (10.5, 24)
            nCells     = 95
            biasFactor = 6
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 5.5)
            nCells     = 52
            biasFactor = -4.5
        }

        Segment {
            bounds     = (5.5, 6.5)
            nCells     = 28
            biasFactor = 1
        }

        Segment {
            bounds     = (6.5, 12)
            nCells     = 52
            biasFactor = 4.5
        }
    }


    Grid z {
        Segment {
            bounds     = (0, 5.5)
            nCells     = 52
            biasFactor = -4.5
        }

        Segment {
            bounds     = (5.5, 6.5)
            nCells     = 28
            biasFactor = 1
        }

        Segment {
            bounds     = (6.5, 12)
            nCells     = 52
            biasFactor = 4.5
        }
    }
}


InitialConditions
{
    type = uniform
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    -y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {

    boundaryTreatement = directionalImmersedBoundary

    Sphere {
        centerPosition = (10, 6, 6)
        diameter       = 1
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = QUICK
        advectionBlendingFactor = 1
        faceInterpolationScheme = weightedLinear

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 100
        maxContinuityOuterResidual = 1e-8
        maxMomentumOuterResiduals  = (1e-8, 1e-8, 1e-8)

    }
    
    LinearSolver {

        type = nestedLineSymmetric
        maxIterations = 3
        maxResiduals = 1e-3

        planeSweepDirection = +y
        lineSweepDirection = +x

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 3

        preSmoothingIterations = 3
        postSmoothingIterations = 3
        fineGridIterations   = 2

        maxCoarseGridIterations = 200
        maxCoarseGridResiduals  = 1e-6
        
    }

}


Output {

    residualHistoryFilename = "output/residualHistory.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

    Monitors {
        ForceCalculator {
            filename = "output/forces.csv"
        }
    }
    

}
