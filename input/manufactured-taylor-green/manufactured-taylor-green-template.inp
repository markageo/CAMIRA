Model {
    nu              = 1
    transient       = no
    TurbulenceModel {
        model = laminar
    }
}

Mesh {

    domainLowerBounds = (-1, -1, -1)
    domainUpperBounds = (1, 1, 1)

    Grid x {
        Segment {
            bounds     = (-1, 1)
            nCells     = $NCELLS
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (-1, 1)
            nCells     = $NCELLS
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (-1, 1)
            nCells     = $NCELLS
            biasFactor = 1
        }
    }
}


InitialConditions
{
    type = uniform
    u = 0
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    +x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    -x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    +y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = $ADVECTION_SCHEME
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = weightedLinear
        
        maxOuterIterations = 10000
        maxContinuityOuterResidual = 1e-12
        maxMomentumOuterResiduals  = (1e-12, 1e-12, 1e-12)

    }
    
    Smoother {

        type = domainSymmetricParallel
        maxIterations = 3
        maxResiduals = 0

        planeSweepDirection = +z
        lineSweepDirection = +y

        eddyViscosityRelaxation = 1
        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = $COARSE_LEVELS

        preSmoothingIterations = 2
        postSmoothingIterations = 2
        fineGridIterations   = 3

        maxCoarseGridIterations = 100
        maxCoarseGridResiduals  = 1e-10

    }

}

Parallel {
    numberOfThreads = 4
}

Output {

    residualHistoryFilename = "$CASE_DIRECTORY/residual_history.csv"
    profilingFilename       = "$CASE_DIRECTORY/profiling.dat"
    fieldOutputFilename     = "$CASE_DIRECTORY/fields.vtk"
    fieldWriteInterval      = 0

}
