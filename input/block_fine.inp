// Block flow

Model {
    nu   = 0.02
    transient = no
}

Mesh {

    domainLowerBounds = (0, 0, 0)
    domainUpperBounds = (10, 4, 3)

    Grid x {
        Segment {
            bounds     = (0, 1.8)
            nCells     = 49
            biasFactor = -2
        }

        Segment {
            bounds     = (1.8, 3.2)
            nCells     = 60
            biasFactor = 1
        }

        Segment {
            bounds     = (3.2, 10)
            nCells     = 166
            biasFactor = 3
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 1)
            nCells     = 39
            biasFactor = 1
        }

        Segment {
            bounds     = (1, 4)
            nCells     = 70
            biasFactor = 2
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 0.8)
            nCells     = 28
            biasFactor = -1.5
        }

        Segment {
            bounds     = (0.8, 2.2)
            nCells     = 60
            biasFactor = 1
        }

        Segment {
            bounds     = (2.2, 3)
            nCells     = 28
            biasFactor = 1.5
        }
    }
}


InitialConditions
{
    type = uniform
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    boundaryTreatement = immersedBoundary
    
    Block {
        centerPosition = (2.5, 0.5, 1.5)
        dimensions     = (1, 1, 1)
        rotation       = (0, 45, 0)
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = semiExplicit
        advectionScheme         = QUICK
        advectionBlendingFactor = 1
        faceInterpolationScheme = weightedLinear
        
        maxOuterIterations = 8
        maxContinuityOuterResidual = 0
        maxMomentumOuterResiduals   = (1e-6, 1e-6, 1e-6)

    }
    
    Smoother {

        type = domainSymmetricParallel
        maxIterations = 3
        maxResiduals = 0

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (0.85, 0.85, 0.85)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 3

        preSmoothingIterations = 3
        postSmoothingIterations = 3
        fineGridIterations   = 2

        maxCoarseGridIterations = 100
        maxCoarseGridResiduals  = 0
        
    }

}

Parallel {
    numberOfThreads = 4
}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

    Monitors {
        Probe {
            filename = "output/probe1.csv"
            location = (1, 0.5, 0.5)
        }
    }

}