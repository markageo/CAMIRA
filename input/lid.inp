// Lid driven cavity

Model {
    rho  = 1
    nu   = 0.005
}

Mesh {

    domain = (1, 1, 1)

    Grid x {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 25
            biasFactor = 1
        }

        Segment {
            bounds     = (0.5, 1)
            nCells     = 25
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 25
            biasFactor = 1
        }

        Segment {
            bounds     = (0.5, 1)
            nCells     = 25
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 25
            biasFactor = 1
        }

        Segment {
            bounds     = (0.5, 1)
            nCells     = 25
            biasFactor = 1
        }
    }
}


InitialConditions
{
    u = 1
    v = 1.2
    w = 3
    p = 0.4
}


BoundaryConditions
{
    // Wall
    +x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Driven
    +y {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = extrapolated
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


Solver {

    Schemes {
        linearisation = Picard

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        advectionScheme = upwind
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 5000
        maxOuterResiduals = 1e-4
    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 1
        maxResiduals = 1e-4

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

        PlaneSolver {
            type = SUGS
            maxIterations = 1
            maxResiduals = 1e-5

            momentumRelaxation = (1, 1, 1)
            pressureRelaxation = 1

            planeSweepDirection = +y


            LineSolver {
                type = SUGS
                maxIterations = 1
                maxResiduals = 1e-3

                momentumRelaxation = (1, 1, 1)
                pressureRelaxation = 1

                lineSweepDirection = +x
            }
        }
    }

}
