// Lid driven cavity

Model {
    rho  = 1
    nu   = 0.005
}

Mesh {

    domain = (1, 1, 1)

    Grid x {
        Segment {
            bounds     = (0, 1)
            nCells     = 128
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 1)
            nCells     = 128
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 1)
            nCells     = 128
            biasFactor = 1
        }
    }
}


InitialConditions
{
    u = 0
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Wall
    +x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Driven
    +y {
        u = uniform, 1
        v = uniform, 1
        w = uniform, 1
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        faceInterpolationScheme = weightedLinear

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 100
        maxOuterResiduals = 1e-6

    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 2
        maxResiduals = 1e-5

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        maxCoarseLevels = 2

        maxPreSmoothingIterations = 2
        maxPreSmoothingResiduals = 0

        maxPostSmoothingIterations = 2
        maxPostSmoothingResiduals = 0

        maxCoarseGridIterations = 10000
        maxCoarseGridResiduals  = 1e-8
        
        maxFineGridIterations   = 3
        maxFineGridResiduals    = 0
        
    }

}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    fieldWriteInterval      = 1

    Monitors {
        Probe {
            filename = "output/probe1.csv"
            location = (0.5, 0.6, 0.5)
        }
    }

}
