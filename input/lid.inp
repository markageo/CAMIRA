// Lid driven cavity

Model {
    nu   = 0.05
    transient = no
}

Mesh {

    domain = (1, 1, 1)

    Grid x {
        Segment {
            bounds     = (0, 1)
            nCells     = 100
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 1)
            nCells     = 100
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 1)
            nCells     = 100
            biasFactor = 1
        }
    }
}


InitialConditions
{
    type = uniform
    u = 0
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Wall
    +x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Driven
    +y {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = semiExplicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = weightedLinear
        
        maxOuterIterations = 10
        maxContinuityOuterResidual = 1e-8
        maxMomentumOuterResiduals  = (1e-8, 1e-8, 1e-8)

    }
    
    Smoother {

        type = domainSymmetric
        maxIterations = 3
        maxResiduals = 0

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 3

        preSmoothingIterations = 3
        postSmoothingIterations = 3
        fineGridIterations   = 3

        maxCoarseGridIterations = 250
        maxCoarseGridResiduals  = 0

    }

}

Parallel {
    numberOfThreads = 3
}

Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    fieldWriteInterval      = 0

}
