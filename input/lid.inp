// Lid driven cavity

Model {
    rho  = 1
    nu   = 0.005
    transient = no
}

Mesh {

    domain = (1, 1, 1)

    Grid x {
        Segment {
            bounds     = (0, 1)
            nCells     = 50
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 1)
            nCells     = 50
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 1)
            nCells     = 50
            biasFactor = 1
        }
    }
}


InitialConditions
{
    type = uniform
    u = 0
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Wall
    +x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Driven
    +y {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = weightedLinear

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 1000
        maxContinuityOuterResidual = 1e-8
        maxMomentumOuterResiduals  = (1e-8, 1e-8, 1e-8)

    }
    
    LinearSolver {

        type = nestedLineSymmetric
        maxIterations = 1
        maxResiduals = 1e-3

        planeSweepDirection = +z
        lineSweepDirection = +x

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 3

        preSmoothingIterations = 3
        postSmoothingIterations = 3
        fineGridIterations   = 2

        maxCoarseGridIterations = 500
        maxCoarseGridResiduals  = 1e-6

    }

}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    fieldWriteInterval      = 0

}
