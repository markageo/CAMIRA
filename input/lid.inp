// Lid driven cavity

Model {
    rho  = 1
    nu   = 100
}

Mesh {

    domain = (0.5, 0.5, 0.5)

    Grid x {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 25
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 25
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 10
            biasFactor = 1
        }
    }
}


InitialConditions
{
    u = 0
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Wall
    +x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Driven
    +y {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = uniform, 0
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}



Solver {

    Schemes {
        linearisation = Picard
        implicitMomentumRelaxation = (0.2, 0.2, 0.2)
        implicitPressureRelaxation = 1

        maxOuterIterations = 10000
        maxOuterResiduals = 1e-3
    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 1
        maxResiduals = 1e-3

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

        PlaneSolver {
            type = SUGS
            maxIterations = 5
            maxResiduals = 1e-2

            momentumRelaxation = (1, 1, 1)
            pressureRelaxation = 1

            planeSweepDirection = +z


            LineSolver {
                type = SUGS
                maxIterations = 1
                maxResiduals = 1e-2

                momentumRelaxation = (1, 1, 1)
                pressureRelaxation = 1

                lineSweepDirection = +x
            }
        }
    }

}
