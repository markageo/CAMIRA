// CEDVAL A1-7 primary input file

Model {
    nu   = 1.5e-5
    transient = no
    TurbulenceModel {
        #include "CEDVAL-A1-7-ZEQ1.inp"
    }
}

Mesh {
    #include "CEDVAL-A1-7-mesh_4.inp"
}


InitialConditions
{    
    type = uniform
    u = 3.425
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = profile1D, "CEDVAL-A1-7-inflow.prof"
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    boundaryTreatement = directionalImmersedBoundary
    Block {
        centerPosition = (0, 0, 0.0625)
        dimensions     = (0.125, 0.125, 0.125)
        rotation       = (0, 0, 40)
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 50
        maxContinuityOuterResidual = 1e-4
        maxMomentumOuterResiduals  = (1e-4, 1e-4, 1e-4)

    }
    
    Smoother {

        type = domainSymmetricParallel
        maxIterations = 3
        maxResiduals = 1e-5

        planeSweepDirection = +z
        lineSweepDirection = +y

        eddyViscosityRelaxation = 1
        momentumRelaxation      = (0.8, 0.8, 0.8)
        pressureRelaxation      = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 3

        preSmoothingIterations = 4
        postSmoothingIterations = 4
        fineGridIterations   = 5

        maxCoarseGridIterations = 50
        maxCoarseGridResiduals  = 1e-10
        
    }

}

Parallel {
    numberOfThreads = 4
}

Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

    Monitors {
        ForceCalculator {
            filename = "output/forces.csv"
        }
    }

}
