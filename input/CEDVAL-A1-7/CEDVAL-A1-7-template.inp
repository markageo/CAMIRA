// CEDVAL A1-7 primary input file

Model {
    nu   = 1.5e-5
    transient = no
    TurbulenceModel {
        #include "CEDVAL-A1-7-ZEQ3.inp"
    }
}

Mesh {
    #include "CEDVAL-A1-7-mesh.inp"
}


InitialConditions
{    
    type = uniform
    u = 3.425
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = profile1D, "CEDVAL-A1-7-inflow.prof"
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    boundaryTreatement = immersedBoundary
    Block {
        centerPosition = (0, 0, 0.0625)
        dimensions     = (0.125, 0.125, 0.125)
        rotation       = (0, 0, 40)
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 25
        maxContinuityOuterResidual = 1e-8
        maxMomentumOuterResiduals  = (1e-8, 1e-8, 1e-8)

    }
    
    Smoother {

        type = domainSymmetricParallel
        maxIterations = 3
        maxResiduals = 1e-5

        planeSweepDirection = $PLANE_SWEEP_DIRECTION
        lineSweepDirection = $LINE_SWEEP_DIRECTION

        eddyViscosityRelaxation = 1
        momentumRelaxation      = (0.85, 0.85, 0.85)
        pressureRelaxation      = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 3

        preSmoothingIterations = 3
        postSmoothingIterations = 3
        fineGridIterations   = 3

        maxCoarseGridIterations = 50
        maxCoarseGridResiduals  = 1e-10
        
    }

}

Parallel {
    numberOfThreads = 8
}

Output {

    residualHistoryFilename = "$CASE_DIRECTORY/residual_history.csv"
    profilingFilename       = "$CASE_DIRECTORY/profiling.dat"
    fieldOutputFilename     = "$CASE_DIRECTORY/fields.vtk"
    geometryOutputFilename  = "$CASE_DIRECTORY/geometry.stl"
    fieldWriteInterval      = 0

    Monitors {
        ForceCalculator {
            filename = "$CASE_DIRECTORY/forces.csv"
        }

        yPlus {
            filename = "$CASE_DIRECTORY/yPlus.csv""
        }
    }

}
