// Lid driven cavity with sphere inside

Model {
    rho  = 1
    nu   = 0.001
    transient = no
}

Mesh {

    domain = (1, 1, 1)

    Grid x {
        Segment {
            bounds     = (0, 1)
            nCells     = 40
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 1)
            nCells     = 40
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 1)
            nCells     = 40
            biasFactor = 1
        }
    }
}

InitialConditions
{
    type  = uniform
    u = 0
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Wall
    +x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Driven
    +y {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    boundaryTreatement = directionalImmersedBoundary
    // FromFile {
    //     type = STL
    //     filename = "lid_sphere_geometry.stl"
    // }

    Sphere {
        centerPosition = (0.5, 0.5, 0.5)
        diameter       = 0.25
    }
}

Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = QUICK
        advectionBlendingFactor = 1
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 500000
        maxContinuityOuterResidual = 1e-12
        maxMomentumOuterResiduals  = (1e-12, 1e-12, 1e-12)
    }
    
    Smoother {

        type = nestedLineSymmetric
        maxIterations = 2
        maxResiduals = 1e-3

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (0.95, 0.95, 0.95)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 1

        preSmoothingIterations = 2
        postSmoothingIterations = 2
        fineGridIterations   = 2

        maxCoarseGridIterations = 200
        maxCoarseGridResiduals  = 1e-6
        
    }

}


Output {

    residualHistoryFilename = "output/residualHistory.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0
}