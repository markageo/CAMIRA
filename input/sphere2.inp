// Sphere flow

Model {
    rho  = 1
    nu   = 0.01
    transient = no
}

Mesh {

    domain = (20, 12, 12)

    Grid x {
        Segment {
            bounds     = (0, 20)
            nCells     = 200
            biasFactor = 1
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 12)
            nCells     = 120
            biasFactor = 1
        }
    }


    Grid z {
        Segment {
            bounds     = (0, 12)
            nCells     = 120
            biasFactor = 1
        }
    }
}


InitialConditions
{
    type = uniform
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    -y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {

    boundaryTreatement = directionalImmersedBoundary

    Sphere {
        centerPosition = (8, 6, 6)
        diameter       = 1
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = SOU
        advectionBlendingFactor = 1
        faceInterpolationScheme = weightedLinear
        
        maxOuterIterations = 100
        maxContinuityOuterResidual = 1e-6
        maxMomentumOuterResiduals  = (1e-6, 1e-6, 1e-6)

    }
    
    Smoother {

        type = nestedLineSymmetric
        maxIterations = 4
        maxResiduals = 1e-3

        planeSweepDirection = +y
        lineSweepDirection = +x

        momentumRelaxation = (0.6, 0.6, 0.6)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 2

        preSmoothingIterations = 2
        postSmoothingIterations = 2
        fineGridIterations   = 2

        maxCoarseGridIterations = 100
        maxCoarseGridResiduals  = 1e-6
        
    }

}


Output {

    residualHistoryFilename = "output/residualHistory.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

    Monitors {
        ForceCalculator {
            filename = "output/forces.csv"
        }
    }
    

}
