// CEDVAL B1-1 primary input file

Model {
    nu   = 1.5e-5
    transient = no
    TurbulenceModel {
        #include "CEDVAL-B1-1-ZEQ3.inp"
    }
}

Mesh {
    #include "CEDVAL-B1-1-mesh.inp"
}


InitialConditions
{    
    type = uniform
    u = 4.51
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = profile1D, "CEDVAL-B1-1-inflow.prof"
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    boundaryTreatement = immersedBoundary
    
    FromFile {
        type = STL
        filename = "input/CEDVAL-B1-1/CEDVAL-B1-1-geometry.stl"
        rotation = (0, 0, 0)
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 100
        maxContinuityOuterResidual = 1e-6
        maxMomentumOuterResiduals  = (1e-6, 1e-6, 1e-6)

    }
    
    Smoother {

        type = domainSymmetricParallel
        maxIterations = 3
        maxResiduals = 1e-5

        planeSweepDirection = +z
        lineSweepDirection = +x

        eddyViscosityRelaxation = 1
        momentumRelaxation      = (0.8, 0.8, 0.8)
        pressureRelaxation      = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 2

        preSmoothingIterations = 2
        postSmoothingIterations = 2
        fineGridIterations   = 5

        maxCoarseGridIterations = 100
        maxCoarseGridResiduals  = 1e-10
        
    }

}

Parallel {
    numberOfThreads = 8
}

Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 0

    Monitors {
        ForceCalculator {
            filename = "output/forces.csv"
        }

        yPlus {
            filename = "output/yPlus.csv""
        }
    }

}
