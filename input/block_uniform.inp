// Block flow

Model {
    rho  = 1
    nu   = 0.0025
    transient = yes
}

Mesh {

    domain = (12, 4, 4)

    Grid x {
        Segment {
            bounds     = (0, 12)
            nCells     = 240
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 4)
            nCells     = 80
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 4)
            nCells     = 80
            biasFactor = 1
        }
    }
}


InitialConditions
{    
    type     = vtkFile
    filename = "output-block-re400/fields_iter999.vtk"
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    Block {
        centerPosition = (2.5, 2, 2)
        dimensions     = (1, 1, 1)
        rotation       = (0, 0, 0)
    }
}


Solver {

    Schemes {

        timeScheme              = backwardsThreeLevel
        timeStepSize            = 0.1
        numberOfTimesteps       = 100

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = QUICK
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = weightedLinear

        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 5
        maxContinuityOuterResidual = 1e-5
        maxMomentumOuterResiduals  = (1e-5, 1e-5, 1e-5)

    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 2
        maxResiduals = 1e-3

        planeSweepDirection = +x
        lineSweepDirection = +z

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 2

        maxPreSmoothingIterations = 2
        maxPreSmoothingResiduals = 0

        maxPostSmoothingIterations = 2
        maxPostSmoothingResiduals = 0

        maxCoarseGridIterations = 500
        maxCoarseGridResiduals  = 1e-4
        
        maxFineGridIterations   = 2
        maxFineGridResiduals    = 0
        
    }

}


Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 1

    Monitors {
        Probe {
            filename = "output/probe1.csv"
            location = (1, 0.5, 0.5)
        }
    }

}
