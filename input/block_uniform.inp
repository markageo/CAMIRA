// Block flow

Model {
    nu   = 0.0005
    transient = no
    TurbulenceModel {
        model = ZEQ0
        heightAxis = y
        averageBuildingHeight = 1
        averageBuildingWidth = 1
        referenceHeight = 1
    }
}

Mesh {

    domain = (20, 4, 4)

    Grid x {
        Segment {
            bounds     = (0, 20)
            nCells     = 200
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (0, 4)
            nCells     = 40
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (0, 4)
            nCells     = 40
            biasFactor = 1
        }
    }
}


InitialConditions
{    
    type = uniform
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    boundaryTreatement = directionalImmersedBoundary
    Block {
        centerPosition = (4, 2, 2)
        dimensions     = (1, 1, 1)
        rotation       = (0, 0, 0)
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 100
        maxContinuityOuterResidual = 1e-6
        maxMomentumOuterResiduals  = (1e-6, 1e-6, 1e-6)

    }
    
    Smoother {

        type = domainSymmetricParallel
        maxIterations = 3
        maxResiduals = 1e-5

        planeSweepDirection = +z
        lineSweepDirection = +y

        eddyViscosityRelaxation = 1
        momentumRelaxation      = (0.8, 0.8, 0.8)
        pressureRelaxation      = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 4

        preSmoothingIterations = 2
        postSmoothingIterations = 2
        fineGridIterations   = 3

        maxCoarseGridIterations = 50
        maxCoarseGridResiduals  = 1e-8
        
    }

}

Parallel {
    numberOfThreads = 4
}

Output {

    residualHistoryFilename = "output/residual_history.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 1

    Monitors {
        ForceCalculator {
            filename = "output/forces.csv"
        }
    }

}
