// Sphere flow

Model {
    nu   = 0.02
    transient = no
}

Mesh {

    domain = (26, 12, 12)

    Grid x {
        Segment {
            bounds     = (0, 8.5)
            nCells     = 159
            biasFactor = -4
        }

        Segment {
            bounds     = (8.5, 9.5)
            nCells     = 55
            biasFactor = 1
        }

        Segment {
            bounds     = (9.5, 26)
            nCells     = 318
            biasFactor = 5
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 5.5)
            nCells     = 110
            biasFactor = -4
        }

        Segment {
            bounds     = (5.5, 6.5)
            nCells     = 55
            biasFactor = 1
        }

        Segment {
            bounds     = (6.5, 12)
            nCells     = 110
            biasFactor = 4
        }
    }


    Grid z {
        Segment {
            bounds     = (0, 5.5)
            nCells     = 110
            biasFactor = -4
        }

        Segment {
            bounds     = (5.5, 6.5)
            nCells     = 55
            biasFactor = 1
        }

        Segment {
            bounds     = (6.5, 12)
            nCells     = 110
            biasFactor = 4
        }
    }
}


InitialConditions
{
    type = uniform
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    -y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {

    boundaryTreatement = directionalImmersedBoundary

    Sphere {
        centerPosition = (9, 6, 6)
        diameter       = 1
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = QUICK
        advectionBlendingFactor = 1
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 100
        maxContinuityOuterResidual = 1e-6
        maxMomentumOuterResiduals  = (1e-6, 1e-6, 1e-6)

    }
    
    Smoother {

        type = domainSymmetricParallel
        maxIterations = 2
        maxResiduals = 1e-3

        planeSweepDirection = +z
        lineSweepDirection = +y

        momentumRelaxation = (0.6, 0.6, 0.6)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 2

        preSmoothingIterations = 3
        postSmoothingIterations = 3
        fineGridIterations   = 2

        maxCoarseGridIterations = 300
        maxCoarseGridResiduals  = 1e-6
        
    }

}


Output {

    residualHistoryFilename = "output/residualHistory.csv"
    profilingFilename       = "output/profiling.dat"
    fieldOutputFilename     = "output/fields.vtk"
    geometryOutputFilename  = "output/geometry.stl"
    fieldWriteInterval      = 1

    Monitors {
        ForceCalculator {
            filename = "output/forces.csv"
        }
    }
    

}
