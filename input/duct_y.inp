// Laminar duct in z direction

Model {
    rho  = 1
    nu   = 1
}

Mesh {

    domain = (0.3, 0.5, 0.1)

    // Cross stream
    Grid x {
        Segment {
            bounds     = (0, 0.3)
            nCells     = 30
            biasFactor = 1
        }
    }

    // Streamwise
    Grid y {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 50
            biasFactor = 1
        }
    }

    // Symmetry
    Grid z {
        Segment {
            bounds     = (0, 0.1)
            nCells     = 1
            biasFactor = 1
        }
    }
}


InitialConditions
{
    u = 0
    v = 1
    w = 0
    p = 0
}


BoundaryConditions
{
    // Wall
    +x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -x {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Outflow
    +y {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -y {
        u = uniform, 0
        v = uniform, 1
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}



Solver {

    Schemes {
        linearisation = Picard
        implicitMomentumRelaxation = (1, 1, 1)
        implicitPressureRelaxation = 1

        maxOuterIterations = 10000
        maxOuterResiduals = 1e-3
    }
    
    LinearSolver {

        type = SUGS
        maxIterations = 1
        maxResiduals = 1e-3

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

        PlaneSolver {
            type = SUGS
            maxIterations = 5
            maxResiduals = 1e-2

            momentumRelaxation = (1, 1, 1)
            pressureRelaxation = 1

            planeSweepDirection = +x


            LineSolver {
                type = SUGS
                maxIterations = 1
                maxResiduals = 1e-2

                momentumRelaxation = (1, 1, 1)
                pressureRelaxation = 1

                lineSweepDirection = +z
            }
        }
    }

}
