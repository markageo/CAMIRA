// Laminar flat plate main input file

Model {
    rho  = 1
    nu   = 1
}

Mesh {

    domain = (5, 6, 7)

    Grid x {
        Segment {
            bounds     = (0, 1)
            nCells     = 5
            biasFactor = 2
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 1)
            nCells     = 6
            biasFactor = 3
        }
    }


    Grid z {
        Segment {
            bounds     = (0, 1)
            nCells     = 7
            biasFactor = 1
        }
    }
}


BoundaryConditions
{

    +x {
        u = extrapolated
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }

    -x {
        u = uniform, 1
        v = uniform, 2
        w = uniform, 3
        p = zeroGradient
    }

    +y {
        u = uniform, 1
        v = extrapolated
        w = zeroGradient
        p = uniform, 0
    }

    -y {
        u = uniform, 0
        v = extrapolated
        w = uniform, 0
        p = extrapolated
    }

    +z {
        u = zeroGradient
        v = zeroGradient
        w = extrapolated
        p = zeroGradient
    }

    -z {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }
}



Solver {

    planeSweepDirection = +y
    lineSweepDirection = +x

    Schemes {
        linearisation = Picard
    }

    PlaneSweeping {
        maxOuterIterations = 1000;
        maxOuterResiduals = 1e-5

        momentumImplicitRelaxation = (0.5, 0.5, 0.5)
        pressureImplicitRelaxation = 1

        maxInnerIterations = 10
        maxInnerResiduals = 1e-3
    }
    
    PlaneSolver {
        type = SUGS
        maxIterations = 100
        maxResiduals = 1e-3

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1
    }

    LineSolver {
        type = SUGS
        maxIterations = 100
        maxResiduals = 1e-3

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1
    }

}
