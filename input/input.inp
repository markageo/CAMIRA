// Laminar flat plate main input file

Model {
    rho  = 1
    nu   = 1
}

Mesh {

    domain = (5, 10, 6)

    Grid X {
        
        Segment {
            bounds     = (0, 1)
            nCells     = 5
            biasFactor = 2
        }

        Segment {
            bounds     = (1, 4)
            nCells     = 25
            biasFactor = 1
        }

        Segment {
            bounds     = (4, 5)
            nCells     = 5
            biasFactor = -2
        }

    }


    Grid Y {
        Segment {
            bounds     = (0, 5)
            nCells     = 20
            biasFactor = 3
        }

        Segment {
            bounds     = (5, 10)
            nCells     = 20
            biasFactor = -3
        }
    }


    Grid Z {
        Segment {
            bounds     = (0, 3)
            nCells     = 10
            biasFactor = 1
        }
    }
}


BoundaryConditions
{

    +x {
        u = extrapolated
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }

    -x {
        u = uniform, 1
        v = uniform, 2
        w = uniform, 3
        p = zeroGradient
    }

    +y {
        u = uniform, 1
        v = extrapolated
        w = zeroGradient
        p = uniform, 0
    }

    -y {
        u = uniform, 0
        v = extrapolated
        w = uniform, 0
        p = extrapolated
    }

    +z {
        u = zeroGradient
        v = zeroGradient
        w = extrapolated
        p = zeroGradient
    }

    -z {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }
}


Solver {

    planeSweepDirection = +z
    lineSweepDirection = +y

}
