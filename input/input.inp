// Laminar flat plate main input file

#include "mesh.inp"

Model {
    rho  = 1
    nu   = 1
}


BoundaryConditions
{

    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }

    -x {
        u = uniform, 1
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    +y {
        u = uniform, 1
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = extrapolated
    }

    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    -z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }
}


Solver {

    planeSweepDirection = z
    lineSweepDirection  = y

}
