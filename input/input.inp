// Laminar flat plate main input file

Model {
    rho  = 1
    nu   = 1
}

Mesh {

    domain = (5, 6, 7)

    Grid X {
        Segment {
            bounds     = (0, 1)
            nCells     = 5
            biasFactor = 2
        }
    }


    Grid Y {
        Segment {
            bounds     = (0, 1)
            nCells     = 6
            biasFactor = 3
        }
    }


    Grid Z {
        Segment {
            bounds     = (0, 1)
            nCells     = 7
            biasFactor = 1
        }
    }
}


BoundaryConditions
{

    +x {
        u = extrapolated
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }

    -x {
        u = uniform, 1
        v = uniform, 2
        w = uniform, 3
        p = zeroGradient
    }

    +y {
        u = uniform, 1
        v = extrapolated
        w = zeroGradient
        p = uniform, 0
    }

    -y {
        u = uniform, 0
        v = extrapolated
        w = uniform, 0
        p = extrapolated
    }

    +z {
        u = zeroGradient
        v = zeroGradient
        w = extrapolated
        p = zeroGradient
    }

    -z {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }
}



Solver {

    planeSweepDirection = +y
    lineSweepDirection = +x

    planeSweeping {
        maxSweeps = 1000;
        maxResidual = 1e-4;

        momentumImplicitRelaxation = (0.5, 0.5, 0.5)
        pressureImplicitRelaxation = 1

        Linearisation = Picard
        maxLinearIterations = 10;
        maxLinearResidual = 1e-3;
    }
    
    planeSolver {
        type = SUGS
        maxIterations = 100
        maxResidual = 1e-3

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1
    }

    lineSolver {
        type = SUGS
        maxIterations = 100
        maxResidual = 1e-3

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1
    }

}
