// Laminar flat plate main input file

Model {
    rho  = 1
    nu   = 1e3
}

Mesh {

    domain = (1, 0.5, 0.5)

    Grid x {
        Segment {
            bounds     = (0, 1)
            nCells     = 10
            biasFactor = 1
        }
    }


    Grid y {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 5
            biasFactor = 1
        }
    }


    Grid z {
        Segment {
            bounds     = (0, 0.5)
            nCells     = 5
            biasFactor = 1
        }
    }
}


InitialConditions
{
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Inflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Outflow
    -x {
        u = uniform, 1
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    +y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Symmetry
    -y {
        u = zeroGradient
        v = uniform, 0
        w = zeroGradient
        p = zeroGradient
    }

    // Freestream
    +z {
        u = uniform, 1
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = extrapolated
    }
}



Solver {

    planeSweepDirection = +z
    lineSweepDirection = +y

    Schemes {
        linearisation = Picard
        implicitMomentumRelaxation = (0.5, 0.5, 0.5)
        implicitPressureRelaxation = 1
    }

    PlaneSweeping {
        maxOuterIterations = 1;
        maxOuterResiduals = 1e-5

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1

        maxInnerIterations = 1
        maxInnerResiduals = 1e-3
    }
    
    PlaneSolver {
        type = SUGS
        maxIterations = 1
        maxResiduals = 1e-3

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1
    }

    LineSolver {
        type = SUGS
        maxIterations = 1
        maxResiduals = 1e-3

        momentumRelaxation = (1, 1, 1)
        pressureRelaxation = 1
    }

}
