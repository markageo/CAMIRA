// Laminar flat plate main input file

Model {
    rho  = 1
    nu   = 1
}


Mesh {

    domain = (1, 1, 1)

    Grid X {
        
        Segment {
            bounds     = (0, 1)
            nCells     = 5
            biasFactor = 2
        }

    }


    Grid Y {
        Segment {
            bounds     = (0, 1)
            nCells     = 5
            biasFactor = 3
        }
    }


    Grid Z {
        Segment {
            bounds     = (0, 1)
            nCells     = 5
            biasFactor = 5
        }
    }
}


BoundaryConditions
{

    +x {
        u = extrapolated
        v = zeroGradient
        w = zeroGradient
        p = zeroGradient
    }

    -x {
        u = extrapolated
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    +y {
        u = uniform, 1
        v = extrapolated
        w = zeroGradient
        p = uniform, 0
    }

    -y {
        u = uniform, 0
        v = extrapolated
        w = uniform, 0
        p = extrapolated
    }

    +z {
        u = zeroGradient
        v = zeroGradient
        w = extrapolated
        p = zeroGradient
    }

    -z {
        u = zeroGradient
        v = zeroGradient
        w = extrapolated
        p = zeroGradient
    }
}


Solver {

    planeSweepDirection = +z
    lineSweepDirection = +y

}
