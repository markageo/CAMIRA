// Instantaneous release point at center of domain plume input file

Model {
    D = 1e-3
    turbulentSchmidtNumber = 1
    timeStepSize = 0.05
    numberOfTimeSteps = 1200
    initialParticlesPerUnitMass = 1e6
    particleSplitTimeStepInterval = 0
    maxNumberOfParticleSplits = 100
}

VelocityField {
    velocityFieldFilename = "flow-output/uniform100_field.vtk"
}

Sources
{
    InstantaneousReleasePoint {
        location = (0, 0, 0)
        totalMass = 1
    }
}


BoundaryConditions
{
    // Outflow
    +x {
        phi = outflow
    }

    // Outflow
    -x {
        phi = outflow
    }

    // Outflow
    +y {
        phi = outflow
    }

    // Outflow
    -y {
        phi = outflow
    }

    // Outflow
    +z {
        phi = outflow
    }

    // Outflow
    -z {
        phi = outflow
    }
}



Parallel {
    numberOfThreads = 4
}

Output {

    outputFormatType        = BINARY
    profilingFilename       = "plume-output/profiling.dat"
    fieldOutputFilename     = "plume-output/fields.vtk"
    fieldWriteInterval      = 1

    TimeAveragedConcentration {
        startTimeStep    = 100
        endTimeStep      = 600
        timeStepInterval = 1
        filename         = "plume-output/average_concentration.vtk"
    }

}
