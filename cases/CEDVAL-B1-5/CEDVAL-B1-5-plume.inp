// CEDVAL B1-5 plume dispersion input file

Model {
    D = 1e-5
    turbulentSchmidtNumber = 0.7
    timeStepSize = 0.1
    numberOfTimeSteps = 600
    initialParticlesPerUnitMass = 1e5
    particleSplitTimeStepInterval = 0
    maxNumberOfParticleSplits = 100
}

VelocityField {
    velocityFieldFilename = "flow-output/fields_iter4.vtk"
}

SolidGeometry {
    filename = flow-output/geometry.stl"
}


Sources
{
    ContinuousReleasePoint {
        location = (-0.07, -0.13, 0.015)
        massFlowRate = 1
    }
}


BoundaryConditions
{
    // Outflow
    +x {
        phi = outflow
    }

    // Inflow
    -x {
        phi = outflow
    }

    // Wall
    +y {
        phi = reflection
    }

    // Wall
    -y {
        phi = reflection
    }

    // Symmetry
    +z {
        phi = outflow
    }

    // Wall
    -z {
        phi = reflection
    }
}



Parallel {
    numberOfThreads = 4
}

Output {

    outputFormatType        = BINARY
    profilingFilename       = "plume-output/profiling.dat"
    fieldOutputFilename     = "plume-output/fields.vtk"
    fieldWriteInterval      = 5

    TimeAveragedConcentration {
        startTimeStep    = 100
        endTimeStep      = 600
        timeStepInterval = 1
        filename         = "plume-output/average_concentration.vtk"
    }

}
