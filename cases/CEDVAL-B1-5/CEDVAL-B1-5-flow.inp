// CEDVAL B1-5 flowfield calculation input file

Model {
    nu   = 1.57e-5
    transient = no
    TurbulenceModel {
        #include "CEDVAL-B1-5-ZEQ3.inp"
    }
}

Mesh {
    #include "CEDVAL-B1-5-mesh.inp"
}


InitialConditions
{    
    type = uniform
    u = 4.21
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Outflow
    +x {
        u = zeroGradient
        v = zeroGradient
        w = zeroGradient
        p = uniform, 0
    }

    // Inflow
    -x {
        u = profile1D, "CEDVAL-B1-5-inflow.prof"
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    +y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -y {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }

    // Symmetry
    +z {
        u = zeroGradient
        v = zeroGradient
        w = uniform, 0
        p = zeroGradient
    }

    // Wall
    -z {
        u = uniform, 0
        v = uniform, 0
        w = uniform, 0
        p = zeroGradient
    }
}


SolidGeometry {
    boundaryTreatment = directionalImmersedBoundary
    
    FromFile {
        type = STL
        filename = "CEDVAL-B1-5-geometry.stl"
        rotation = (0, 0, -29)
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = upwind
        advectionBlendingFactor = 1.0
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 1000
        maxContinuityOuterResidual = 1e-4
        maxMomentumOuterResiduals  = (1e-4, 1e-4, 1e-4)

    }
    
    Smoother {

        type = domainSymmetricParallel
        maxIterations = 2
        maxResiduals = 1e-5

        planeSweepDirection = +z
        lineSweepDirection = +y

        eddyViscosityRelaxation = 1
        momentumRelaxation      = (0.9, 0.9, 0.9)
        pressureRelaxation      = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 2

        preSmoothingIterations = 2
        postSmoothingIterations = 2
        fineGridIterations   = 5

        maxCoarseGridIterations = 100
        maxCoarseGridResiduals  = 1e-10
        
    }

}

Parallel {
    numberOfThreads = 8
}

Output {

    residualHistoryFilename = "flow-output/residual_history.csv"
    profilingFilename       = "flow-output/profiling.dat"
    fieldOutputFilename     = "flow-output/fields.vtk"
    geometryOutputFilename  = "flow-output/geometry.stl"
    fieldWriteInterval      = 0

    Monitors {
        ForceCalculator {
            filename = "flow-output/forces.csv"
        }

        yPlus {
            filename = "flow-output/yPlus.csv""
        }
    }

}
