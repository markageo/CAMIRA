// Instantaneous release point at center of domain flow field file


Model {
    nu   = 1
    transient = no
    TurbulenceModel {
        model = laminar
    }
}

Mesh {

    domainLowerBounds = ( -0.25, -1, -1 )
    domainUpperBounds = ( 5,  1,  1 )

    Grid x {
        Segment {
            bounds     = (-0.25, 5)
            nCells     = 263
            biasFactor = 1
        }
    }

    Grid y {
        Segment {
            bounds     = (-1, 1)
            nCells     = 100
            biasFactor = 1
        }
    }

    Grid z {
        Segment {
            bounds     = (-1, 1)
            nCells     = 100
            biasFactor = 1
        }
    }
}

InitialConditions
{
    type  = uniform
    u = 1
    v = 0
    w = 0
    p = 0
}


BoundaryConditions
{
    // Wall
    +x {
        u = extrapolated
        v = extrapolated
        w = extrapolated
        p = zeroGradient
    }

    // Wall
    -x {
        u = extrapolated
        v = extrapolated
        w = extrapolated
        p = zeroGradient
    }

    // Driven
    +y {
        u = extrapolated
        v = extrapolated
        w = extrapolated
        p = zeroGradient
    }

    // Wall
    -y {
        u = extrapolated
        v = extrapolated
        w = extrapolated
        p = zeroGradient
    }

    // Wall
    +z {
        u = extrapolated
        v = extrapolated
        w = extrapolated
        p = zeroGradient
    }

    // Wall
    -z {
        u = extrapolated
        v = extrapolated
        w = extrapolated
        p = zeroGradient
    }
}


Solver {

    Schemes {

        linearisation           = Picard
        momentumInterpolation   = implicit
        advectionScheme         = QUICK
        advectionBlendingFactor = 1
        faceInterpolationScheme = weightedLinear

        maxOuterIterations = 0
        maxContinuityOuterResidual = 1e-6
        maxMomentumOuterResiduals  = (1e-6, 1e-6, 1e-6)
    }
    
    Smoother {

        type = nestedLineSymmetricSerial
        maxIterations = 3
        maxResiduals = 1e-3

        planeSweepDirection = +y
        lineSweepDirection = +x

        eddyViscosityRelaxation = 1
        momentumRelaxation = (0.98, 0.98, 0.98)
        pressureRelaxation = 1

    }

    Multigrid {
        cycle = F
        maxCoarseLevels = 2

        preSmoothingIterations = 2
        postSmoothingIterations = 2
        fineGridIterations   = 2

        maxCoarseGridIterations = 150
        maxCoarseGridResiduals  = 1e-12
        
    }

}

Parallel {
    numberOfThreads = 4
}


Output {

    outputFormatType        = BINARY
    residualHistoryFilename = "flow-output/residual_history.csv"
    profilingFilename       = "flow-output/profiling.dat"
    fieldOutputFilename     = "flow-output/fields.vtk"
    fieldWriteInterval      = 0
}